# Public-web search adapters. Diagnosis grounding stays disabled until an
# end-to-end SLA canary passes. Keep keys server-side only.
PUBLIC_WEB_GROUNDING_ENABLED=false
# Comma-separated backend providers. The legacy singular variable remains a fallback.
PUBLIC_WEB_GROUNDING_PROVIDERS=volcengine,anysearch
PUBLIC_WEB_GROUNDING_PROVIDER=volcengine
DIAGNOSIS_SLA_MS=30000
DIAGNOSIS_REPORT_RESERVE_MS=2500
WEB_SEARCH_MAX_RESULTS=5
